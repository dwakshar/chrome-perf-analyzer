{
  "manifest_version": 3,
  "name": "Chrome Perf Analyzer",
  "short_name": "Perf Analyzer",
  "version": "1.0.0",
  "description": "Inspect Core Web Vitals inside Chrome DevTools and surface actionable page performance issues.",

  "permissions": ["alarms", "debugger", "storage"],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "devtools_page": "devtools/devtools.html",

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script/content-script.js"],
      "run_at": "document_start"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["panel/panel.html", "panel/panel.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "DevTools Performance Analyzer"
  },

  "minimum_chrome_version": "109"
}
